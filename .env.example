# Resend API key — obtain from https://resend.com/api-keys
# Use the "Development" key here; production key goes in Vercel env vars
RESEND_API_KEY=

# The email address that receives contact-form submissions.
# During development, point this at your own inbox so you don't disturb the stakeholder.
CONTACT_TO_EMAIL=

# Root domain used for the "From" address (e.g. softfinity.com).
# The function sends from hello@send.<CONTACT_DOMAIN>.
# Requires SPF/DKIM/DMARC records on the send. subdomain — see docs/runbooks/contact-form.md.
CONTACT_DOMAIN=softfinity.com

# Optional: Discord webhook URL for lead-capture redundancy (ADR-0006 option E).
# If set, every submission is also posted to the Discord channel in parallel with Resend.
# If unset, webhook fan-out is skipped.
DISCORD_WEBHOOK_URL=
